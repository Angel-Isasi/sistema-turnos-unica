# Copia este archivo como .env y completa los valores reales.
# El .env NUNCA se sube a git (ya está en .gitignore).

# Conexión MySQL de Railway (pestaña Variables del servicio MySQL).
# Ojo: el driver es mysql+pymysql, no mysql a secas.
DATABASE_URL=mysql+pymysql://usuario:password@host:puerto/nombre_bd

# Clave con la que se firman los JWT. En producción usa un valor largo y
# aleatorio (por ejemplo: python -c "import secrets; print(secrets.token_hex(48))")
JWT_SECRET=cambia-esto-por-un-valor-largo-y-aleatorio

# Orígenes permitidos por CORS, separados por coma y SIN barra final.
# En desarrollo: el dev server de Vite. En producción: tu dominio de Vercel.
CORS_ORIGINS=http://localhost:5173

# "desarrollo" deja /docs abierto; "produccion" lo apaga.
ENTORNO=desarrollo
