# URL del backend. En desarrollo no hace falta definirla (usa
# http://localhost:8000 por defecto). En Vercel se configura como variable
# de entorno del proyecto apuntando al backend desplegado en Railway.
#
# OJO: cualquier variable VITE_* queda compilada dentro del JavaScript y es
# visible para cualquiera. Aquí solo va la URL pública del backend — nunca
# credenciales ni secretos.
VITE_API_URL=http://localhost:8000
